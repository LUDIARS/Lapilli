{
  "name": "@ludiars/blackbox",
  "version": "0.2.0",
  "description": "Growth-type black box: LLM-first decisions distilled into serializable rules that graduate from the LLM (LUDIARS)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./file": {
      "import": "./dist/store-jsonfile.js",
      "types": "./dist/store-jsonfile.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=threads"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LUDIARS/Lapilli.git",
    "directory": "packages/blackbox"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
