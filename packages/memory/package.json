{
  "name": "@ludiars/memory",
  "version": "0.1.0",
  "description": "LUDIARS memory and skill hygiene utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./analysis": {
      "import": "./dist/analysis.js",
      "types": "./dist/analysis.d.ts"
    },
    "./archive": {
      "import": "./dist/archive.js",
      "types": "./dist/archive.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=threads"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LUDIARS/Lapilli.git",
    "directory": "packages/memory"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
